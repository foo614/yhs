# Copy this file to .env in the repository root before running Docker Compose on a VPS.
# Keep production secrets out of git and replace the example domains with your VPS domains or public IP URLs.

POSTGRES_DB=ysheng
POSTGRES_USER=ysheng
POSTGRES_PASSWORD=change-this-database-password

SEED_ADMIN_EMAIL=admin@ysheng.local
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_DATA_ENABLED=true
ASPNETCORE_ENVIRONMENT=Production

POSTGRES_PORT=5432
API_PORT=5000
FRONTOFFICE_PORT=3000
BACKOFFICE_PORT=3001

PUBLIC_API_BASE_URL=https://api.example.com
FRONTOFFICE_ORIGIN=https://www.example.com
BACKOFFICE_ORIGIN=https://admin.example.com
